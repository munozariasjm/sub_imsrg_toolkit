#!/bin/bash
#SBATCH --job-name=test
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=24
#SBATCH --output=/work/submit/abelley/results/imsrg_log/outputs/test_out_%j.txt
#SBATCH --error=/work/submit/abelley/results/imsrg_log/errors/test_err_%j.txt
#SBATCH --time=10:00

cd $SLURM_SUBMIT_DIR
export OMP_NUM_THREADS=24
apptainer exec \
  --bind /home/submit \
  --bind /work/submit \
  --bind /scratch/submit \
  --bind /cvmfs \
  --bind /ceph/submit \
  /work/submit/abelley/pyimsrg.sif python3 /work/submit/abelley/imsrg_toolkit/test.py
